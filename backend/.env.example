# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_leads?schema=public

# Adzuna API
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# Cron (default: every 6 hours)
CRON_ENABLED=true
CRON_SCHEDULE=0 */6 * * *

# Collector safety limits
MAX_PAGES_PER_RUN=40
RESULTS_PER_PAGE=50
